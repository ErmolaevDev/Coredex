# Copy to deploy/docker.env and adjust secrets for docker-compose.
# cp deploy/docker.env.example deploy/docker.env

COREDEX_ENV=production
COREDEX_HTTP_PORT=8080
COREDEX_LOG_LEVEL=info

# Graceful shutdown timeout for http.Server.Shutdown
COREDEX_SHUTDOWN_TIMEOUT=30s

# HTTP server timeouts
COREDEX_HTTP_READ_TIMEOUT=30s
COREDEX_HTTP_WRITE_TIMEOUT=30s
COREDEX_HTTP_IDLE_TIMEOUT=120s

# Optional: comma-separated browser origins (enables CORS middleware)
# COREDEX_CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Optional: per-IP rate limit (0 = disabled)
COREDEX_RATE_LIMIT_RPS=100
COREDEX_RATE_LIMIT_BURST=200

# Connect to the postgres service (see docker-compose.yml)
DB_HOST=postgres
DB_PORT=5432
DB_USER=coredex
DB_PASSWORD=coredex
DB_NAME=coredex
DB_SSLMODE=disable

# Required: replace with strong secrets in real deployments
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h

# Required: openssl rand -base64 32 (example decodes to 32 bytes — replace in production)
VAULT_ENCRYPTION_KEY=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=
