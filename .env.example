# Coredex API — copy to .env for local development (optional; godotenv loads .env if present)
COREDEX_ENV=development
COREDEX_HTTP_PORT=8080
COREDEX_LOG_LEVEL=info
# Set to debug to see JWT middleware logs (auth_token_received, auth_user_id_parsed).
# COREDEX_LOG_LEVEL=debug

# PostgreSQL (required for API startup)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=coredex
DB_PASSWORD=changeme
DB_NAME=coredex
# Optional: disable (local), require (managed cloud), etc.
# DB_SSLMODE=disable

# JWT (required). Use a long random secret in production.
JWT_SECRET=change-me-to-a-long-random-string
# Optional access-token lifetime (Go duration), default 24h
# JWT_EXPIRES_IN=24h

# AES-256 vault for /assets (required): base64 of exactly 32 random bytes. Example: openssl rand -base64 32
VAULT_ENCRYPTION_KEY=

# Production-style HTTP (optional; defaults shown)
# COREDEX_SHUTDOWN_TIMEOUT=30s
# COREDEX_HTTP_READ_TIMEOUT=30s
# COREDEX_HTTP_WRITE_TIMEOUT=30s
# COREDEX_HTTP_IDLE_TIMEOUT=120s

# Optional CORS (comma-separated origins). In development, http://localhost:3000 is used when unset.
# COREDEX_CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Optional per-IP rate limit (COREDEX_RATE_LIMIT_RPS=0 disables)
# COREDEX_RATE_LIMIT_RPS=100
# COREDEX_RATE_LIMIT_BURST=200
